{
  "_meta": {
    "version": "2.0",
    "purpose": "Seed pool for insight card orchestrator. Values are axes of variation, not content. LLM generates actual topics, titles and card text at runtime from these seeds.",
    "usage": "Orchestrator samples one theme and one human_context from the category-specific pool per run. All other slots rotate globally.",
    "excluded_always": [
      "news",
      "current events",
      "statistics",
      "data references",
      "citations",
      "harmful",
      "hateful",
      "abusive",
      "sexual",
      "unsafe"
    ]
